# ── Azure AI Foundry ──────────────────────────────────────────────
AZURE_FOUNDRY_ENDPOINT=https://<your-project>.services.ai.azure.com/models
AZURE_FOUNDRY_API_KEY=<your-api-key>
AZURE_FOUNDRY_MODEL=gpt-4o-mini          # model deployment name in Foundry

# ── API Security ──────────────────────────────────────────────────
# Power Automate will send this in the X-API-Key header
API_SECRET_KEY=<generate-a-strong-secret>

# ── App Settings ──────────────────────────────────────────────────
APP_ENV=development                      # development | production
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=20
ALLOWED_EXTENSIONS=.docx,.vtt

# ── BRD Template ─────────────────────────────────────────────────
# Absolute path to your company .docx template on the server
BRD_TEMPLATE_PATH=./templates/brd_template.docx
